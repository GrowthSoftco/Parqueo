# --- Base de datos (Neon Postgres, conexión "pooled") ---
# Rota la clave en Neon antes de producción.
DATABASE_URL="postgresql://usuario:CLAVE@ep-xxxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require&uselibpqcompat=true"

# --- Sesión ---
# Secreto para firmar la cookie de login. Genera uno con: openssl rand -hex 32
AUTH_SECRET="pon_aqui_un_secreto_largo"

# --- Tiempo real (Pusher) — pusher.com -> crea una app "Channels" -> pestaña "App Keys" ---
# Si no las pones, la app funciona igual pero sin actualizaciones en vivo.
PUSHER_APP_ID="tu_app_id"
PUSHER_SECRET="tu_secret"
NEXT_PUBLIC_PUSHER_KEY="tu_key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# --- Solo para empaquetar la app de escritorio (Electron) ---
# La URL ya desplegada en Vercel. No se usa en la web.
# APP_URL="https://tu-app.vercel.app"
